source "https://rubygems.org"

# Use a modern Jekyll version that plays nice with Arch
gem "jekyll", "~> 4.4.1"

group :jekyll_plugins do
  gem "jekyll-remote-theme"
  gem "jekyll-include-cache"
  gem "jekyll-seo-tag"
  gem "jekyll-feed"
  gem "jekyll-sitemap"
end

# Fix for the Faraday warning you saw earlier
gem "faraday-retry"

